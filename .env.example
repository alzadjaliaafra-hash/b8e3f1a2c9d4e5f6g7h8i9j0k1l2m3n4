# Copy to .env and fill in real values. Do not commit .env.

# -----------------------------------------------------------------------------
# Go backend (cmd/server)
# -----------------------------------------------------------------------------

# Postgres connection string (pgx format). The default points at the
# postgres service in docker-compose.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/srff_rvs?sslmode=disable

# Port the Go backend listens on.
PORT=8080

# Optional: path to the Alif logo PNG used by the PDF generator. If unset,
# the PDF is rendered without the logo.
IC_MEMO_LOGO_PATH=

# -----------------------------------------------------------------------------
# RVS Python sidecar
# -----------------------------------------------------------------------------

# When set, the Go RVSEngineImpl dispatches to this URL instead of running
# the local stub arithmetic. Point at the FastAPI service in
# backend/python_rvs_service (docker-compose service name: python-rvs).
PYTHON_RVS_URL=http://localhost:8001

# -----------------------------------------------------------------------------
# Murshidi AI (Claude)
# -----------------------------------------------------------------------------

# Required when you swap NoopMurshidiClient for the real Anthropic client.
# Get a key from https://console.anthropic.com/.
ANTHROPIC_API_KEY=

# Optional: override the Claude model used for qualitative analysis.
# Leave empty to use the Go default (currently claude-opus-4-7).
MURSHIDI_MODEL=

# -----------------------------------------------------------------------------
# Angular frontend (frontend/)
# -----------------------------------------------------------------------------

# Not read by the backend. The frontend's environment files drive this;
# this entry is a reminder for local dev.
API_BASE_URL=http://localhost:8080
